# -- Keith's PokeBS -- .gitignore --------------------------------------
# Structure: tcg_tracker/ root with plugins/, dashboard/, data/, tests/

# Browser profile -- contains retailer login cookies (SENSITIVE)
.browser_profile/

# INTERNAL folder -- local notes, scratch files, never commit
INTERNAL/

# Runtime-generated JSON at root (untracked via: git rm --cached *.json)
future_events.json
price_history.json
restock_history.json
status_snapshot.json
store_inventory.json

# All generated runtime data (data/ folder)
data/
*.json
*.log
*.log.*

# Exception -- keep these source-controlled
!products_backup.txt
!requirements.txt

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Virtual environment
venv/
env/
.venv/
.env/
"__pycache__/" 
"*.pyc" 
"*.pyo" 
