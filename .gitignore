# -- Keith's PokeBS -- .gitignore --------------------------------------
# Structure: tcg_tracker/ root with plugins/, dashboard/, data/, tests/

# ==========================================================================
# SENSITIVE - Never commit
# ==========================================================================

# Browser profile - contains retailer login cookies
.browser_profile/

# Local config (lives in %LOCALAPPDATA%, but defensive against accidental copy)
config.json
*_cookies.json

# Backup files from migrations
*.bak

# ==========================================================================
# Runtime-generated data
# ==========================================================================

# Runtime JSON at root (legacy paths - kept for safety)
future_events.json
price_history.json
restock_history.json
status_snapshot.json
store_inventory.json

# All generated runtime data
data/
*.json
*.log
*.log.*

# Exception - keep these source-controlled
!products_backup.txt
!requirements.txt

# ==========================================================================
# Python
# ==========================================================================

__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/

# Virtual environments
venv/
env/
.venv/
.env/

# ==========================================================================
# OS / Editor
# ==========================================================================

.DS_Store
Thumbs.db
desktop.ini

# ==========================================================================
# Defensive - stray temporary files
# ==========================================================================

v2
v3
v4
PROJECT_KNOWLEDGE.txt 
apply_v*.py 
*.bak       
.patches_archive/
